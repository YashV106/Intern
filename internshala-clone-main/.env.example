# =========================
# Backend - required variables
# =========================

# Render should set this in the environment
PORT=5000

# MongoDB (Render)
# Provide either a single DATABASE_URL or keep the others unused.
# Example:
# DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/mydb?retryWrites=true&w=majority
DATABASE_URL=

# JWT
JWT_SECRET=

# Cookie/session (if your auth/middleware uses cookies; safe to keep empty if unused)
COOKIE_SECRET=

# Nodemailer / OTP email
OTP_EMAIL_HOST=
OTP_EMAIL_PORT=587
OTP_EMAIL_USER=
OTP_EMAIL_PASS=

# Optional additional env vars commonly referenced in codebase
LOGIN_TIMEZONE=Asia/Kolkata

# If you use any third-party API keys in the backend, list them here:
# API_KEYS=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
